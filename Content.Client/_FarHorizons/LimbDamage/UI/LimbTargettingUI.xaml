<limbDamage:LimbTargettingUI 
    xmlns="https://spacestation14.io"
    xmlns:limbDamage="clr-namespace:Content.Client._FarHorizons.LimbDamage.UI"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    MinSize="64 64">
    <PanelContainer 
        Name="BackgroundPanel"
        MinWidth="100" 
        MinHeight="100" 
        MaxWidth="100" 
        MaxHeight="100">
        <PanelContainer.PanelOverride>
            <gfx:StyleBoxTexture 
                PatchMarginBottom="6"
                PatchMarginTop="6"
                PatchMarginLeft="6"
                PatchMarginRight="6"
                TextureScale="2 2"
                Mode="Tile"/>
        </PanelContainer.PanelOverride>
        <limbDamage:LimbTargettingDisplay Name="LimbTargettingDisplay"/>
    </PanelContainer>
</limbDamage:LimbTargettingUI>
